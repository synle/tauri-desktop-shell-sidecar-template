{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set: allows shell-open and the example-sidecar binary.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/example-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
